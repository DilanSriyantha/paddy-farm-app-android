<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/containerNotification"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp"
    android:background="@drawable/bg_primary_surface">

    <TextView
        android:id="@+id/txtNotificationTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/title"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/imgNotificationUnreadIndicator" />

    <ImageView
        android:id="@+id/imgNotificationUnreadIndicator"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:src="@drawable/baseline_circle_24"
        app:layout_constraintTop_toTopOf="@id/txtNotificationTitle"
        app:layout_constraintBottom_toBottomOf="@id/txtNotificationTitle"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtNotificationContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/title"
        android:textSize="14sp"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/txtNotificationTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtNotificationDatetime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/notification_datetime"
        android:textStyle="italic"
        android:textSize="11sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtNotificationContent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>